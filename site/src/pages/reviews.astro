---
import Base from "../layouts/Base.astro";
import PendingReviews from "../islands/PendingReviews";
---

<Base title="Plugin Reviews — Vicert Marketplace" description="View plugin submissions under review">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl font-bold text-white mb-2">Plugin Reviews</h1>
    <p class="text-gray-400 mb-8">
      Track plugin submissions and updates. Pull requests are reviewed by marketplace maintainers before being merged.
    </p>
    <PendingReviews client:load />
  </section>
</Base>
