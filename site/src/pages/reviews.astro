---
import Base from "../layouts/Base.astro";
import PendingReviews from "../islands/PendingReviews";
---

<Base title="Plugin Reviews — Vicert Marketplace" description="View plugin submissions under review">
  <section class="border-b-2 border-swiss-black">
    <div class="p-6 lg:p-8 py-8 sm:py-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <div class="flex items-center gap-3 mb-2">
          <h1 class="text-2xl sm:text-3xl font-black tracking-tight">Plugin Reviews</h1>
          <span class="swiss-badge-black">Review</span>
        </div>
        <p class="text-sm text-gray-600 max-w-lg leading-relaxed">
          Track submissions and updates. Pull requests are reviewed by maintainers before merging.
        </p>
      </div>
    </div>
  </section>

  <section class="p-6 lg:p-8 max-w-4xl">
    <PendingReviews client:load />
  </section>
</Base>
