---
import Base from "../layouts/Base.astro";
import ClaudeCodeDocs from "../islands/ClaudeCodeDocs";
---

<Base title="Claude Code Docs — Vicert Marketplace" description="Browse Claude Code documentation — overview, skills, agents, hooks, MCP servers, plugins, settings, and more">
  <section class="border-b border-gray-300">
    <div class="p-6 lg:p-8 py-8 sm:py-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <div class="flex items-center gap-3 mb-2">
          <h1 class="text-2xl sm:text-3xl font-black tracking-tight">Docs</h1>
          <span class="swiss-badge-black">Claude Code</span>
        </div>
        <p class="text-sm text-gray-600 max-w-lg leading-relaxed">
          Claude Code documentation. Browse topics including skills, agents, hooks, MCP servers, plugins, settings, and more.
        </p>
      </div>
      <a
        href="https://code.claude.com/docs"
        target="_blank"
        rel="noopener noreferrer"
        class="text-xs font-bold text-vicert-blue hover:text-vicert-blue-dark transition-colors whitespace-nowrap"
      >
        code.claude.com/docs
      </a>
    </div>
  </section>

  <section class="border-swiss-black">
    <ClaudeCodeDocs client:load />
  </section>
</Base>
