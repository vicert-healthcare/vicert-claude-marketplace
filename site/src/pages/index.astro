---
import Base from "../layouts/Base.astro";
import PluginBrowser from "../islands/PluginBrowser";
---

<Base title="Vicert Claude Code Marketplace" description="Browse, discover, and install Claude Code plugins from the Vicert community marketplace">
  <section class="py-16 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto text-center">
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4">
        Claude Code Marketplace
      </h1>
      <p class="text-lg text-gray-400 max-w-2xl mx-auto mb-8">
        Discover and install community-built plugins for Claude Code.
        Skills, agents, commands, MCP servers, and more.
      </p>

      <div class="bg-gray-800/50 border border-gray-700 rounded-xl p-4 max-w-lg mx-auto mb-10 font-mono text-sm">
        <span class="text-gray-500">$</span>
        <span class="text-green-400 ml-2">/plugin marketplace add vicert-healthcare/vicert-claude-marketplace</span>
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <PluginBrowser client:load />
  </section>
</Base>
