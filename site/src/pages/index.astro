---
import Base from "../layouts/Base.astro";
import PluginBrowser from "../islands/PluginBrowser";
---

<Base title="Vicert Claude Code Marketplace" description="Browse, discover, and install Claude Code plugins from the Vicert community marketplace">
  <section class="border-b border-gray-300">
    <div class="p-6 lg:p-8 py-10 sm:py-14 lg:py-16">
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-vicert-blue mb-4">Plugin Marketplace</p>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-tight mb-4 leading-[1.1] max-w-2xl">
          Extend Claude Code<br class="hidden sm:block" /> with community plugins
        </h1>
        <p class="text-base text-gray-600 max-w-lg leading-relaxed mb-8">
          Skills, agents, commands, hooks, MCP servers — browse and install with a single command.
        </p>

        <div>
          <p class="text-[10px] font-bold uppercase tracking-widest text-gray-300 mb-2">Quick start</p>
          <div class="bg-swiss-black text-swiss-white p-4 font-mono text-xs sm:text-sm inline-flex items-center gap-3">
            <span class="text-gray-500">$</span>
            <span>/plugin marketplace add vicert-healthcare/vicert-claude-marketplace</span>
            <button
              id="hero-copy-btn"
              title="Copy to clipboard"
              class="text-gray-400 hover:text-white transition-colors flex-shrink-0"
            >
              <svg id="hero-copy-icon" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
              </svg>
              <svg id="hero-check-icon" class="w-4 h-4 text-green-400 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </button>
            <span id="hero-copied-label" class="text-[10px] font-bold text-green-400 hidden">Copied!</span>
          </div>
        </div>

        <script>
          const btn = document.getElementById("hero-copy-btn");
          const copyIcon = document.getElementById("hero-copy-icon");
          const checkIcon = document.getElementById("hero-check-icon");
          const copiedLabel = document.getElementById("hero-copied-label");

          if (btn) {
            btn.addEventListener("click", async () => {
              await navigator.clipboard.writeText("/plugin marketplace add vicert-healthcare/vicert-claude-marketplace");
              copyIcon?.classList.add("hidden");
              checkIcon?.classList.remove("hidden");
              copiedLabel?.classList.remove("hidden");
              setTimeout(() => {
                copyIcon?.classList.remove("hidden");
                checkIcon?.classList.add("hidden");
                copiedLabel?.classList.add("hidden");
              }, 2000);
            });
          }
        </script>
      </div>
    </div>
  </section>

  <section class="p-6 lg:p-8">
    <PluginBrowser client:load />
  </section>
</Base>
