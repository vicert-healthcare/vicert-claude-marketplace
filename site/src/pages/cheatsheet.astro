---
import Base from "../layouts/Base.astro";
import CheatSheet from "../islands/CheatSheet";
---

<Base title="Claude Code Cheat Sheet — Vicert Marketplace" description="Quick reference for all Claude Code commands, keyboard shortcuts, slash commands, MCP, memory, agents, and CLI flags">
  <section class="border-b-2 border-swiss-black">
    <div class="p-6 lg:p-8 py-8 sm:py-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <div class="flex items-center gap-3 mb-2">
          <h1 class="text-2xl sm:text-3xl font-black tracking-tight">Cheat Sheet</h1>
          <span class="swiss-badge-black">v2.1.81</span>
        </div>
        <p class="text-sm text-gray-600 max-w-lg leading-relaxed">
          Quick reference for all Claude Code commands, keyboard shortcuts, slash commands, MCP servers, memory files, agents, and CLI flags.
        </p>
      </div>
      <div class="flex items-center gap-3">
        <div class="text-xs text-gray-600 font-medium whitespace-nowrap">
          Last updated: March 24, 2026
        </div>
        <button onclick="window.print()" class="text-xs font-bold border-2 border-swiss-black px-3 py-1.5 hover:bg-swiss-black hover:text-white transition-colors flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
          </svg>
          Print
        </button>
      </div>
    </div>
  </section>

  <section class="p-6 lg:p-8">
    <CheatSheet client:load />
  </section>
</Base>
