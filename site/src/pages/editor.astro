---
import Base from "../layouts/Base.astro";
import PluginEditor from "../islands/PluginEditor";
---

<Base title="Plugin Editor — Vicert Marketplace" description="Create or edit a plugin for the Vicert Claude Code Marketplace">
  <section class="border-b border-gray-300">
    <div class="p-6 lg:p-8 py-8 sm:py-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <div class="flex items-center gap-3 mb-2">
          <h1 class="text-2xl sm:text-3xl font-black tracking-tight">Plugin Editor</h1>
          <span class="swiss-badge-blue">Submit</span>
        </div>
        <p class="text-sm text-gray-600 max-w-lg leading-relaxed">
          Create a new plugin or edit an existing one. Submissions open a pull request for review.
        </p>
      </div>
    </div>
  </section>

  <section class="p-6 lg:p-8 max-w-4xl">
    <PluginEditor client:load />
  </section>
</Base>
