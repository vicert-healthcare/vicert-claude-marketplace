---
import Base from "../layouts/Base.astro";
import PluginEditor from "../islands/PluginEditor";
---

<Base title="Plugin Editor — Vicert Marketplace" description="Create or edit a plugin for the Vicert Claude Code Marketplace">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl font-bold text-white mb-2">Plugin Editor</h1>
    <p class="text-gray-400 mb-8">
      Create a new plugin or edit an existing one. Upload an entire folder or fill in the form.
      Your submission will automatically open a pull request for review.
    </p>
    <PluginEditor client:load />
  </section>
</Base>
