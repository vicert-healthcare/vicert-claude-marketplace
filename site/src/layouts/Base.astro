---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const { title = "Vicert Claude Code Marketplace", description = "Browse, discover, and install Claude Code plugins" } = Astro.props;
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const marketplaceItems = [
  {
    name: "Browse",
    href: base,
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" /></svg>`,
    mobileLabel: "Browse",
  },
  {
    name: "Reviews",
    href: `${base}reviews`,
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>`,
    mobileLabel: "Reviews",
  },
  {
    name: "Submit Plugin",
    href: `${base}editor`,
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>`,
    mobileLabel: "Submit",
  },
];

const claudeCodeItems = [
  {
    name: "Docs",
    href: `${base}docs`,
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>`,
    mobileLabel: "Docs",
  },
  {
    name: "Official Plugins",
    href: `${base}official-plugins`,
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 14v6m-3-3h6M6 10h2a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v2a2 2 0 002 2zm10 0h2a2 2 0 002-2V6a2 2 0 00-2-2h-2a2 2 0 00-2 2v2a2 2 0 002 2zM6 20h2a2 2 0 002-2v-2a2 2 0 00-2-2H6a2 2 0 00-2 2v2a2 2 0 002 2z" /></svg>`,
    mobileLabel: "Official",
  },
  {
    name: "Changelog",
    href: `${base}news`,
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg>`,
    mobileLabel: "Changelog",
  },
];

const externalItems = [
  {
    name: "GitHub",
    href: "https://github.com/vicert-healthcare/vicert-claude-marketplace",
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>`,
    external: true,
    mobileLabel: "GitHub",
  },
];

const allNavItems = [...marketplaceItems, ...claudeCodeItems];

function isActive(itemHref: string, current: string) {
  const norm = (p: string) => p.replace(/\/+$/, '') || '/';
  return norm(current) === norm(itemHref);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title}</title>
  </head>
  <body class="h-screen overflow-hidden bg-gray-100 text-swiss-black font-sans">

    <!-- Header -->
    <header class="h-14 bg-swiss-black text-swiss-white flex items-center flex-shrink-0 z-40">
      <a href={base} class="hidden lg:flex items-center gap-3 w-56 px-5 hover:opacity-90 transition-opacity flex-shrink-0 border-r border-white/10">
        <img src={`${base}favicon.svg`} alt="Vicert" class="h-5" />
        <span class="text-sm text-gray-300 font-medium">Marketplace</span>
      </a>
      <a href={base} class="lg:hidden flex items-center gap-3 px-5 hover:opacity-90 transition-opacity">
        <img src={`${base}favicon.svg`} alt="Vicert" class="h-5" />
        <span class="hidden sm:block text-sm text-gray-300 font-medium">Plugin Marketplace</span>
      </a>

      <div class="flex items-center gap-5 ml-auto px-5">
        <a
          href="https://github.com/vicert-healthcare/vicert-claude-marketplace"
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:flex items-center gap-2 text-xs text-gray-400 hover:text-white font-medium transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          Source
        </a>
        <a
          href="https://code.claude.com"
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:block text-xs text-gray-400 hover:text-white font-medium transition-colors"
        >
          Powered by Claude Code
        </a>
      </div>
    </header>

    <!-- Body: sidebar + scrollable content -->
    <div class="flex h-[calc(100vh-56px)]">

      <!-- Sidebar (desktop) -->
      <aside class="w-56 bg-swiss-white border-r-2 border-swiss-black hidden lg:flex flex-col flex-shrink-0">
        <nav class="py-5 flex-1 overflow-y-auto">
          <p class="px-5 mb-3 text-[10px] font-bold uppercase tracking-widest text-gray-300">Marketplace</p>
          <ul class="space-y-0.5">
            {marketplaceItems.map((item) => {
              const active = isActive(item.href, currentPath);
              return (
                <li>
                  <a
                    href={item.href}
                    class={`flex items-center gap-3 px-5 py-2.5 text-sm font-medium transition-colors ${
                      active
                        ? "bg-swiss-black text-swiss-white"
                        : "text-swiss-black hover:bg-gray-100"
                    }`}
                  >
                    <Fragment set:html={item.icon} />
                    <span>{item.name}</span>
                  </a>
                </li>
              );
            })}
          </ul>

          <div class="mt-6">
            <p class="px-5 mb-3 text-[10px] font-bold uppercase tracking-widest text-gray-300">Claude Code</p>
            <ul class="space-y-0.5">
              {claudeCodeItems.map((item) => {
                const active = isActive(item.href, currentPath);
                return (
                  <li>
                    <a
                      href={item.href}
                      class={`flex items-center gap-3 px-5 py-2.5 text-sm font-medium transition-colors ${
                        active
                          ? "bg-swiss-black text-swiss-white"
                          : "text-swiss-black hover:bg-gray-100"
                      }`}
                    >
                      <Fragment set:html={item.icon} />
                      <span>{item.name}</span>
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>

          <div class="mt-6">
            <p class="px-5 mb-3 text-[10px] font-bold uppercase tracking-widest text-gray-300">External</p>
            <ul>
              {externalItems.map((item) => (
                <li>
                  <a
                    href={item.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-3 px-5 py-2.5 text-sm font-medium text-gray-600 hover:text-swiss-black hover:bg-gray-100 transition-colors"
                  >
                    <Fragment set:html={item.icon} />
                    <span>{item.name}</span>
                    <svg class="w-3 h-3 ml-auto opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </nav>

        <!-- Sidebar footer -->
        <div class="border-t-2 border-gray-200 px-5 py-4">
          <p class="text-[10px] text-gray-300 font-medium uppercase tracking-wider">&copy; {new Date().getFullYear()} Vicert Healthcare</p>
        </div>
      </aside>

      <!-- Scrollable content -->
      <main class="flex-1 min-w-0 overflow-y-auto pb-16 lg:pb-0">
        <slot />
      </main>
    </div>

    <!-- Mobile bottom nav -->
    <nav class="lg:hidden fixed bottom-0 left-0 right-0 bg-swiss-white border-t-2 border-swiss-black z-50">
      <ul class="flex justify-around py-1.5">
        {allNavItems.map((item) => {
          const active = isActive(item.href, currentPath);
          return (
            <li>
              <a
                href={item.href}
                class={`flex flex-col items-center px-2 py-1.5 transition-colors ${
                  active ? "text-swiss-blue" : "text-gray-600"
                }`}
              >
                <Fragment set:html={item.icon} />
                <span class="text-[10px] mt-1 font-bold">{item.mobileLabel}</span>
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

  </body>
</html>
